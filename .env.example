# ===========================================================================
# Southwest Rebooker - Environment configuration (EXAMPLE)
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ===========================================================================

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# error | warn | info | debug
LOG_LEVEL=info
# Set to "true" to enable verbose debug logging (NEVER logs credentials).
DEBUG_MODE=false

# ---------------------------------------------------------------------------
# Price monitoring / polling
# ---------------------------------------------------------------------------
# How often (minutes) the background poller checks current prices.
POLL_INTERVAL_MINUTES=360
# Notify when potential savings meet/exceed these thresholds.
SAVINGS_ALERT_THRESHOLD_USD=25
SAVINGS_ALERT_THRESHOLD_POINTS=2000

# ---------------------------------------------------------------------------
# Points valuation (cents per Rapid Rewards point)
# ---------------------------------------------------------------------------
DEFAULT_POINT_VALUE_CENTS=1.4

# ---------------------------------------------------------------------------
# Southwest scraping (Playwright)
# ---------------------------------------------------------------------------
# "true" launches a visible browser (useful to solve CAPTCHA / debug).
SCRAPER_HEADFUL=false
# Per-navigation timeout in milliseconds.
SCRAPER_TIMEOUT_MS=45000
# Base URL (override only if Southwest changes domains).
SOUTHWEST_BASE_URL=https://www.southwest.com

# ---------------------------------------------------------------------------
# Secure storage
# ---------------------------------------------------------------------------
# OS keychain service name used for credential entries.
KEYCHAIN_SERVICE=SouthwestRebooker
